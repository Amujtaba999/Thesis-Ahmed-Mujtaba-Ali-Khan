# 7. Create final monthly panel

crsp_for_merge <- crsp %>%
  mutate(
    formation_year = ifelse(sample_month >= 7, sample_year, sample_year - 1)
  )

panel <- crsp_for_merge %>%
  left_join(permno_gvkey_link, by = "permno") %>%
  filter(!is.na(gvkey)) %>%
  inner_join(
    comp,
    by = c("gvkey", "formation_year")
  ) %>%
  left_join(ff5, by = "date") %>%
  left_join(
    ratios_unique,
    by = c("permno" = "permno", "date" = "public_date")
  ) %>%
  mutate(
    excess_return = stock_return - rf,
    
    automation = w_log_automation,
    automation_raw = w_automation_intensity,
    
    size = w_size_assets,
    book_to_market = coalesce(w_bm_ratio, w_book_to_market_comp),
    profitability = coalesce(w_roa_ratio, w_profitability_comp),
    leverage = coalesce(w_debt_assets_ratio, w_leverage_comp),
    investment = w_asset_growth,
    
    productivity_channel = w_productivity,
    efficiency_channel = w_efficiency,
    cost_flexibility_channel = w_cost_flexibility,
    
    sic2 = floor(sic / 100),
    
    industry_group = case_when(
      sic >= 1000 & sic <= 1499 ~ "Mining",
      sic >= 1500 & sic <= 1799 ~ "Construction",
      sic >= 2000 & sic <= 3999 ~ "Manufacturing",
      sic >= 4000 & sic <= 4899 ~ "Transport_Communication",
      sic >= 5000 & sic <= 5999 ~ "Trade",
      sic >= 7000 & sic <= 8999 ~ "Services",
      TRUE ~ "Other"
    )
  ) %>%
  filter(!is.na(excess_return)) %>%
  filter(!is.na(automation)) %>%
  filter(!is.na(size)) %>%
  filter(!is.na(book_to_market)) %>%
  filter(!is.na(profitability)) %>%
  filter(!is.na(leverage)) %>%
  filter(!is.na(sic2)) %>%
  arrange(permno, date, gvkey) %>%
  group_by(permno, date) %>%
  slice(1) %>%
  ungroup()

write_csv(panel, "data/processed/final_monthly_panel.csv")

