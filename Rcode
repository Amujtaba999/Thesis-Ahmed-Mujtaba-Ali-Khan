# 4. Clean Compustat annual fundamentals

comp_raw <- add_missing_columns(
  comp_raw,
  c(
    "datafmt", "indfmt", "consol", "curcd", "gvkey", "fyear",
    "sic", "naics", "cusip", "tic", "conm", "at", "sale",
    "emp", "ppent", "ppegt", "capx", "xrd", "xsga", "cogs",
    "dp", "ni", "oibdp", "lt", "dlc", "dltt", "ceq", "seq",
    "csho", "prcc_f", "mkvalt"
  )
)

comp <- comp_raw %>%
  mutate(
    gvkey = as.character(gvkey),
    fyear = as.integer(fyear),
    sic = as.integer(sic),
    naics_comp = as.character(naics),
    cusip = as.character(cusip),
    cusip8 = str_sub(cusip, 1, 8),
    tic = as.character(tic),
    conm = as.character(conm),
    
    at = as.numeric(at),
    sale = as.numeric(sale),
    emp = as.numeric(emp),
    ppent = as.numeric(ppent),
    ppegt = as.numeric(ppegt),
    capx = as.numeric(capx),
    xrd = as.numeric(xrd),
    xsga = as.numeric(xsga),
    cogs = as.numeric(cogs),
    dp = as.numeric(dp),
    ni = as.numeric(ni),
    oibdp = as.numeric(oibdp),
    lt = as.numeric(lt),
    dlc = as.numeric(dlc),
    dltt = as.numeric(dltt),
    ceq = as.numeric(ceq),
    seq = as.numeric(seq),
    csho = as.numeric(csho),
    prcc_f = as.numeric(prcc_f),
    mkvalt = as.numeric(mkvalt)
  ) %>%
  filter(is.na(datafmt) | datafmt == "STD") %>%
  filter(is.na(indfmt) | indfmt == "INDL") %>%
  filter(is.na(consol) | consol == "C") %>%
  filter(is.na(curcd) | curcd == "USD") %>%
  filter(!is.na(gvkey), !is.na(fyear)) %>%
  filter(at > 0) %>%
  filter(emp > 0) %>%
  filter(!is.na(ppent), ppent >= 0)

# Exclude financials and utilities
comp <- comp %>%
  filter(!(sic >= 6000 & sic <= 6999)) %>%
  filter(!(sic >= 4900 & sic <= 4999))

comp <- comp %>%
  arrange(gvkey, fyear) %>%
  group_by(gvkey) %>%
  mutate(
    lag_at = lag(at),
    asset_growth = (at - lag_at) / lag_at,
    sales_growth = (sale - lag(sale)) / lag(sale)
  ) %>%
  ungroup() %>%
  mutate(
    # Main automation proxy
    automation_intensity = ppent / emp,
    log_automation = log(1 + automation_intensity),
    
    # Alternative automation proxies
    capex_intensity = capx / at,
    rd_intensity = ifelse(is.na(xrd), 0, xrd) / at,
    capital_intensity_assets = ppent / at,
    
    # Channels
    productivity = sale / emp,
    efficiency = sale / at,
    sga_intensity = ifelse(!is.na(sale) & sale > 0, xsga / sale, NA_real_),
    cogs_intensity = ifelse(!is.na(sale) & sale > 0, cogs / sale, NA_real_),
    cost_flexibility = -sga_intensity,
    
    # Controls
    size_assets = log(at),
    market_equity_comp = ifelse(!is.na(mkvalt), mkvalt, prcc_f * csho),
    size_market = log(market_equity_comp),
    book_equity = coalesce(seq, ceq),
    book_to_market_comp = book_equity / market_equity_comp,
    profitability_comp = oibdp / at,
    roa_comp = ni / at,
    leverage_comp = lt / at,
    book_leverage = (dltt + dlc) / at,
    tangibility = ppent / at,
    
    # Timing rule:
    # Fiscal year t explains monthly returns from July t+1 to June t+2.
    formation_year = fyear + 1
  )

comp <- comp %>%
  group_by(fyear) %>%
  mutate(
    w_log_automation = winsorize(log_automation),
    w_automation_intensity = winsorize(automation_intensity),
    w_capex_intensity = winsorize(capex_intensity),
    w_rd_intensity = winsorize(rd_intensity),
    w_productivity = winsorize(productivity),
    w_efficiency = winsorize(efficiency),
    w_cost_flexibility = winsorize(cost_flexibility),
    w_size_assets = winsorize(size_assets),
    w_book_to_market_comp = winsorize(book_to_market_comp),
    w_profitability_comp = winsorize(profitability_comp),
    w_roa_comp = winsorize(roa_comp),
    w_leverage_comp = winsorize(leverage_comp),
    w_asset_growth = winsorize(asset_growth),
    w_tangibility = winsorize(tangibility)
  ) %>%
  ungroup()

write_csv(comp, "data/processed/compustat_clean.csv")

