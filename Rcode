# 1. Helper functions

winsorize <- function(x, probs = c(0.01, 0.99)) {
  if (all(is.na(x))) return(x)
  q <- quantile(x, probs = probs, na.rm = TRUE)
  x <- ifelse(x < q[1], q[1], x)
  x <- ifelse(x > q[2], q[2], x)
  return(x)
}

compound_return <- function(r) {
  if (all(is.na(r))) return(NA_real_)
  prod(1 + r[!is.na(r)]) - 1
}

parse_date_safe <- function(x) {
  x <- as.character(x)
  parsed <- suppressWarnings(lubridate::ymd(x))
  if (all(is.na(parsed))) {
    parsed <- suppressWarnings(lubridate::dmy(x))
  }
  if (all(is.na(parsed))) {
    parsed <- suppressWarnings(lubridate::mdy(x))
  }
  return(parsed)
}

add_missing_columns <- function(data, cols) {
  for (col in cols) {
    if (!col %in% names(data)) {
      data[[col]] <- NA
    }
  }
  return(data)
}


