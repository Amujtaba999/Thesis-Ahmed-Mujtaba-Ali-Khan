# 17. High-minus-low portfolio and factor alpha

hml_automation <- ew_returns %>%
  select(date, automation_portfolio, ew_return) %>%
  pivot_wider(
    names_from = automation_portfolio,
    values_from = ew_return,
    names_prefix = "p"
  ) %>%
  mutate(
